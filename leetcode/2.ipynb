   "source": [
    "class Solution:\n",
    "    def strStr(self, haystack: str, needle: str) -> int:\n",
    "        if needle not in haystack :\n",
    "            return -1\n",
    "        else : \n",
    "            return haystack.find(needle)\n",
    "        \n",
    "ex= Solution().strStr(\"sadbutsad\" , \"ad\")\n",
    "print(ex)"
   ]
